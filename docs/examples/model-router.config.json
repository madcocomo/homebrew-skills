{
  "version": 1,
  "mode": "off",
  "models": {
    "classifier": { "provider": "deepseek", "id": "deepseek-v4-flash", "supportsImages": false },
    "weak": { "provider": "google", "id": "gemini-3.5-flash", "supportsImages": true }
  },
  "classification": {
    "ruleProfile": "conservative-v1",
    "minWeakConfidence": 0.9,
    "timeoutMs": 20000,
    "maxInputChars": 12000
  },
  "limits": {
    "maxWeakContinuationTurns": 4,
    "maxNoProgressTurns": 2,
    "maxRepeatedOperationCount": 2
  },
  "logging": {
    "directory": "~/.pi/agent/model-router-logs",
    "maxReasonChars": 240
  }
}
